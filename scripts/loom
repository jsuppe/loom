#!/usr/bin/env python3
"""
Thin compatibility shim around ``loom.cli:main``.

After ``pip install`` the ``loom`` console script registered in
``pyproject.toml`` is the canonical entry point. This script exists so
that running directly from a repo clone still works without an
install: it puts ``src/`` on ``sys.path`` and delegates.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from loom.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
