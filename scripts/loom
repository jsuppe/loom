#!/usr/bin/env python3
"""
Loom CLI - Requirements traceability for AI-assisted development.

Usage:
    loom extract [--session <key>] [--project <name>]
    loom check <file> [--lines <range>] [--project <name>]
    loom link <file> [--lines <range>] [--req <id>...] [--project <name>]
    loom status [--project <name>]
    loom query <text> [--project <name>]
    loom list [--all] [--project <name>]

Exit codes:
    0 — Success
    1 — Error (bad input, missing resource, store failure)
    2 — Warning condition detected (drift, conflicts found)

Most read-only commands accept --json / -j for machine-readable output.
"""

import sys
import os
import json
import argparse
import hashlib
from pathlib import Path
from datetime import datetime, timezone

# Add src to path
SKILL_DIR = Path(__file__).parent.parent
sys.path.insert(0, str(SKILL_DIR / "src"))

from store import LoomStore, Requirement, Implementation, Specification, Pattern, generate_impl_id, generate_content_hash


# Simple LRU cache for embeddings (avoids repeated Ollama calls)
_embedding_cache = {}
_CACHE_MAX_SIZE = 500


def _cache_key(text: str) -> str:
    """Generate cache key from text content."""
    return hashlib.sha256(text.encode()).hexdigest()[:16]


def get_project_name():
    """Detect project name from current directory or env."""
    if os.environ.get("LOOM_PROJECT"):
        return os.environ["LOOM_PROJECT"]
    
    # Try to detect from git
    try:
        import subprocess
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            return Path(result.stdout.strip()).name
    except:
        pass
    
    return "default"


def get_embedding(text: str, model: str = "nomic-embed-text", max_retries: int = 3, use_cache: bool = True) -> list:
    """
    Get embedding for text using Ollama.
    
    Uses nomic-embed-text by default (768 dimensions).
    Falls back to hash-based pseudo-embedding if Ollama unavailable.
    
    Args:
        text: Text to embed
        model: Ollama model name
        max_retries: Number of retry attempts for transient failures
        use_cache: Whether to use embedding cache (default True)
    """
    import urllib.request
    import urllib.error
    import time
    
    # Check cache first
    if use_cache:
        cache_key = _cache_key(text)
        if cache_key in _embedding_cache:
            return _embedding_cache[cache_key]
    
    last_error = None
    for attempt in range(max_retries):
        try:
            data = json.dumps({"model": model, "input": text}).encode()
            req = urllib.request.Request(
                "http://localhost:11434/api/embed",
                data=data,
                headers={"Content-Type": "application/json"}
            )
            with urllib.request.urlopen(req, timeout=30) as resp:
                result = json.loads(resp.read().decode())
                embedding = result["embeddings"][0]
                
                # Cache the result
                if use_cache:
                    # Simple LRU: clear oldest if at capacity
                    if len(_embedding_cache) >= _CACHE_MAX_SIZE:
                        # Remove first item (oldest)
                        oldest_key = next(iter(_embedding_cache))
                        del _embedding_cache[oldest_key]
                    _embedding_cache[cache_key] = embedding
                
                return embedding
        except (urllib.error.URLError, TimeoutError, ConnectionResetError) as e:
            last_error = e
            if attempt < max_retries - 1:
                # Exponential backoff: 1s, 2s, 4s
                wait_time = 2 ** attempt
                time.sleep(wait_time)
                continue
        except KeyError as e:
            # Bad response format - don't retry
            last_error = e
            break
    
    # All retries failed - fallback to hash-based pseudo-embedding
    print(f"⚠️  Ollama unavailable after {max_retries} attempts, using fallback embeddings: {last_error}")
    h = hashlib.sha256(text.encode()).digest()
    embedding = []
    for i in range(768):  # Match nomic-embed-text dimensions
        byte_idx = i % 32
        embedding.append((h[byte_idx] - 128) / 128.0)
    
    # Cache fallback too
    if use_cache:
        if len(_embedding_cache) >= _CACHE_MAX_SIZE:
            oldest_key = next(iter(_embedding_cache))
            del _embedding_cache[oldest_key]
        _embedding_cache[cache_key] = embedding
    
    return embedding


def cmd_extract(args):
    """Extract requirements from current session context."""
    store = LoomStore(args.project)
    
    print(f"🧵 Loom Extract — Project: {args.project}")
    print()
    print("To extract requirements, provide them in this format:")
    print()
    print("  REQUIREMENT: <domain> | <requirement text>")
    print()
    print("Domains: terminology, behavior, ui, data, architecture")
    print()
    print("Example:")
    print("  REQUIREMENT: behavior | Reset button requires 3-second hold with visual feedback")
    print()
    
    # For agent use: read from stdin or args
    if args.text:
        lines = [args.text]
    elif not sys.stdin.isatty():
        lines = sys.stdin.read().strip().split('\n')
    else:
        print("Provide requirements via --text or stdin")
        return 1
    
    extracted = 0
    for line in lines:
        if line.strip().upper().startswith("REQUIREMENT:"):
            content = line.split(":", 1)[1].strip()
            if "|" in content:
                domain, value = content.split("|", 1)
                domain = domain.strip().lower()
                value = value.strip()
                
                # Generate ID
                timestamp = datetime.now(timezone.utc).isoformat()
                req_id = f"REQ-{hashlib.sha256(f'{domain}:{value}'.encode()).hexdigest()[:8]}"
                
                req = Requirement(
                    id=req_id,
                    domain=domain,
                    value=value,
                    source_msg_id=args.msg_id or "manual",
                    source_session=args.session or "cli",
                    timestamp=timestamp,
                    rationale=getattr(args, 'rationale', None)
                )
                
                # Check for conflicts before adding
                try:
                    from docs import check_conflicts
                    conflicts = check_conflicts(store, req, get_embedding_fn=get_embedding)
                    if conflicts:
                        print(f"⚠️  CONFLICT DETECTED for: {value}")
                        for c in conflicts:
                            existing = c["existing"]
                            print(f"   Conflicts with {existing.id}: {existing.value}")
                        print(f"   → Consider using `loom supersede {conflicts[0]['existing'].id}` first")
                        print()
                except ImportError:
                    pass  # docs module not available
                
                embedding = get_embedding(value)
                store.add_requirement(req, embedding)
                print(f"✓ {req_id}: [{domain}] {value}")
                extracted += 1
    
    print()
    print(f"Extracted {extracted} requirement(s)")
    return 0


def cmd_check(args):
    """Check a file for drift against linked requirements."""
    store = LoomStore(args.project)

    if not Path(args.file).exists():
        if getattr(args, 'json', False):
            print(json.dumps({"error": f"File not found: {args.file}"}))
        else:
            print(f"File not found: {args.file}")
        return 1

    content = Path(args.file).read_text()

    if args.lines:
        start, end = map(int, args.lines.split("-"))
        lines = content.split('\n')
        content = '\n'.join(lines[start-1:end])

    impl_id = generate_impl_id(args.file, args.lines or "all")
    impl = store.get_implementation(impl_id)

    if not impl:
        if getattr(args, 'json', False):
            print(json.dumps({"file": args.file, "linked": False, "requirements": []}))
        else:
            print(f"🧵 Loom Check — {args.file}")
            print()
            print("No requirements linked to this file/section.")
            print("Run `loom link` to create links.")
        return 0

    # Check for drift
    drift_found = False
    results = []
    for sat in impl.satisfies:
        req = store.get_requirement(sat["req_id"])
        if req:
            drifted = req.superseded_at is not None
            if drifted:
                drift_found = True
            results.append({
                "req_id": sat["req_id"],
                "value": req.value,
                "domain": req.domain,
                "status": req.status,
                "drifted": drifted,
                "superseded_at": req.superseded_at
            })

    if getattr(args, 'json', False):
        print(json.dumps({
            "file": args.file,
            "lines": args.lines,
            "linked": True,
            "drift_detected": drift_found,
            "requirements": results
        }, indent=2))
    else:
        print(f"🧵 Loom Check — {args.file}")
        print()
        for r in results:
            if r["drifted"]:
                print(f"⚠️  DRIFT: {r['req_id']} was superseded at {r['superseded_at']}")
                print(f"   Old: {r['value']}")
            else:
                print(f"✓ {r['req_id']}: {r['value']}")
        if drift_found:
            print()
            print("Some linked requirements have changed. Review before modifying.")

    return 2 if drift_found else 0


def cmd_link(args):
    """Link code to requirements and/or specifications."""
    import hashlib
    store = LoomStore(args.project)

    print(f"🧵 Loom Link — {args.file}")
    print()

    if not Path(args.file).exists():
        print(f"File not found: {args.file}")
        return 1

    content = Path(args.file).read_text()

    if args.lines:
        start, end = map(int, args.lines.split("-"))
        lines_content = content.split('\n')
        content = '\n'.join(lines_content[start-1:end])

    impl_id = generate_impl_id(args.file, args.lines or "all")
    content_hash = generate_content_hash(content)

    # Build satisfies list (requirements) and satisfies_specs (specifications)
    satisfies = []
    satisfies_specs = []

    spec_ids = getattr(args, 'spec', None) or []
    req_ids = getattr(args, 'req', None) or []

    # Resolve spec IDs first
    for spec_id in spec_ids:
        spec = store.get_specification(spec_id)
        if spec:
            satisfies_specs.append(spec_id)
            # Auto-link to parent requirement too
            if not any(s["req_id"] == spec.parent_req for s in satisfies):
                parent_req = store.get_requirement(spec.parent_req)
                if parent_req:
                    satisfies.append({"req_id": spec.parent_req, "req_version": parent_req.timestamp})
        else:
            print(f"Warning: spec {spec_id} not found")

    # Handle --req
    for req_id in req_ids:
        req = store.get_requirement(req_id)
        if req:
            # Warn if this requirement has specs but user is linking directly
            existing_specs = store.get_specifications_for_requirement(req_id)
            active_specs = [s for s in existing_specs if not s.superseded_at]
            if active_specs and not spec_ids:
                print(f"⚠️  {req_id} has {len(active_specs)} active specification(s).")
                print(f"   Consider linking to a spec instead of the requirement directly:")
                for s in active_specs:
                    print(f"     {s.id}: {s.description[:60]}")
                print(f"   Continuing with direct link to {req_id}...")
                print()
            if not any(s["req_id"] == req_id for s in satisfies):
                satisfies.append({"req_id": req_id, "req_version": req.timestamp})
        else:
            print(f"Warning: {req_id} not found")

    # Auto-detect if nothing specified
    if not satisfies and not satisfies_specs:
        embedding = get_embedding(content)
        results = store.search_requirements(embedding, n=3)
        results = [r for r in results if r['requirement'].superseded_at is None]
        print("Detected requirements (confirm with --req or --spec):")
        for r in results:
            print(f"  {r['id']}: {r['requirement'].value}")
            satisfies.append({"req_id": r['id'], "req_version": r['requirement'].timestamp})

    if not satisfies and not satisfies_specs:
        print("No requirements or specs to link.")
        return 1

    impl = Implementation(
        id=impl_id,
        file=args.file,
        lines=args.lines or "all",
        content=content,
        content_hash=content_hash,
        timestamp=datetime.now(timezone.utc).isoformat(),
        satisfies=satisfies,
        satisfies_specs=satisfies_specs or None,
    )

    embedding = get_embedding(content)
    store.add_implementation(impl, embedding)

    print()
    if satisfies_specs:
        print(f"✓ Linked {args.file} to {len(satisfies_specs)} spec(s) and {len(satisfies)} requirement(s)")
    else:
        print(f"✓ Linked {args.file} to {len(satisfies)} requirement(s)")
    return 0


def cmd_status(args):
    """Show requirements status."""
    store = LoomStore(args.project)
    stats = store.stats()

    # Check for drift
    all_reqs = store.list_requirements(include_superseded=True)
    superseded = [r for r in all_reqs if r.superseded_at]
    active = [r for r in all_reqs if not r.superseded_at]

    drift_items = []
    for req in superseded:
        impls = store.get_implementations_for_requirement(req.id)
        for impl in impls:
            drift_items.append({
                "file": impl.file,
                "lines": impl.lines,
                "req_id": req.id,
                "req_value": req.value,
                "superseded_at": req.superseded_at
            })

    if getattr(args, 'json', False):
        print(json.dumps({
            "project": args.project,
            "requirements": stats['requirements'],
            "active": len(active),
            "superseded": len(superseded),
            "implementations": stats['implementations'],
            "chat_messages": stats['chat_messages'],
            "drift_count": len(drift_items),
            "drift": drift_items
        }, indent=2))
    else:
        print(f"🧵 Loom Status — Project: {args.project}")
        print()
        print(f"Requirements: {stats['requirements']}")
        print(f"Implementations: {stats['implementations']}")
        print(f"Chat messages: {stats['chat_messages']}")
        print()

        if superseded:
            print(f"Superseded requirements: {len(superseded)}")
            for d in drift_items:
                print(f"  ⚠️ {d['file']} → {d['req_id']} (superseded)")
            if drift_items:
                print()
                print(f"⚠️  {len(drift_items)} implementation(s) need review")
        else:
            print("No drift detected ✓")

    return 0


def cmd_query(args):
    """Search requirements semantically."""
    store = LoomStore(args.project)

    embedding = get_embedding(args.text)
    results = store.search_requirements(embedding, n=args.limit or 5)

    if getattr(args, 'json', False):
        output = []
        for r in results:
            req = r['requirement']
            output.append({
                "id": req.id,
                "domain": req.domain,
                "value": req.value,
                "status": req.status,
                "superseded": req.superseded_at is not None,
                "source": req.source_session,
                "timestamp": req.timestamp,
                "distance": r.get("distance")
            })
        print(json.dumps(output, indent=2))
        return 0

    print(f"🧵 Loom Query: {args.text}")
    print()

    if not results:
        print("No matching requirements found.")
        return 0

    for r in results:
        req = r['requirement']
        status = "✓" if not req.superseded_at else "⚠️ superseded"
        print(f"{req.id} [{req.domain}] {status}")
        print(f"  {req.value}")
        print(f"  Source: {req.source_session} @ {req.timestamp}")
        print()

    return 0


def cmd_list(args):
    """List all requirements."""
    store = LoomStore(args.project)
    
    reqs = store.list_requirements(include_superseded=args.all)
    
    # JSON output mode for API consumption
    if args.json:
        from testspec import TestSpecStore
        spec_store = TestSpecStore(store.data_dir)
        
        output = []
        for req in reqs:
            spec = spec_store.get_spec(req.id)
            output.append({
                "id": req.id,
                "domain": req.domain,
                "text": req.value,
                "status": req.status,
                "elaboration": req.elaboration,
                "rationale": req.rationale,
                "acceptance_criteria": req.acceptance_criteria or [],
                "test_spec_id": req.test_spec_id,
                "conversation_context": req.conversation_context,
                "is_complete": req.is_complete(),
                "has_test": spec is not None,
                "superseded": req.superseded_at is not None
            })
        print(json.dumps(output, indent=2))
        return 0
    
    # Human-readable output
    print(f"🧵 Loom Requirements — Project: {args.project}")
    print()
    
    if not reqs:
        print("No requirements found.")
        return 0
    
    for req in reqs:
        status_parts = []
        if req.superseded_at:
            status_parts.append("superseded")
        if req.status != "pending":
            status_parts.append(req.status)
        if not req.is_complete():
            status_parts.append("needs refinement")
        
        status = f" ({', '.join(status_parts)})" if status_parts else ""
        print(f"{req.id} [{req.domain}]{status}")
        print(f"  {req.value}")
        if req.elaboration:
            print(f"  📝 {req.elaboration[:60]}...")
    
    print()
    print(f"Total: {len(reqs)}")
    
    incomplete = [r for r in reqs if not r.is_complete()]
    if incomplete:
        print(f"⚠️  {len(incomplete)} need refinement (run: loom incomplete)")
    
    return 0


def cmd_sync(args):
    """Sync/regenerate REQUIREMENTS.md and TEST_SPEC.md."""
    from docs import generate_requirements_doc, generate_test_spec_doc
    from testspec import TestSpecStore
    
    store = LoomStore(args.project)
    output_dir = Path(args.output) if args.output else Path.cwd()
    
    public_mode = args.public
    mode_label = " (PUBLIC)" if public_mode else ""
    
    print(f"🧵 Loom Sync — Project: {args.project}{mode_label}")
    print()
    
    # Load test specs
    spec_store = TestSpecStore(store.data_dir)
    specs = {s.req_id: s for s in spec_store.list_specs()}
    private_ids = spec_store.get_private_ids()
    
    # Also mark specs marked as private
    for spec in specs.values():
        if spec.private:
            private_ids.add(spec.req_id)
    
    if public_mode and private_ids:
        print(f"Excluding {len(private_ids)} private requirement(s)")
        print()
    
    # Generate requirements doc
    req_path = generate_requirements_doc(store, output_dir, private_ids, public_mode)
    print(f"✓ Generated {req_path}")
    
    # Generate test spec doc
    test_path = generate_test_spec_doc(store, output_dir, specs, private_ids, public_mode)
    print(f"✓ Generated {test_path}")
    
    return 0


def cmd_conflicts(args):
    """Check for conflicts with a potential new requirement."""
    from docs import check_conflicts

    store = LoomStore(args.project)

    if not args.text:
        if getattr(args, 'json', False):
            print(json.dumps({"error": "Provide requirement text with --text"}))
        else:
            print("Provide requirement text with --text")
        return 1

    # Parse domain and value
    if "|" in args.text:
        domain, value = args.text.split("|", 1)
        domain = domain.strip().lower()
        value = value.strip()
    else:
        domain = "behavior"
        value = args.text.strip()

    # Create temporary requirement for checking
    temp_req = Requirement(
        id="TEMP",
        domain=domain,
        value=value,
        source_msg_id="conflict-check",
        source_session="cli",
        timestamp=datetime.now(timezone.utc).isoformat()
    )

    conflicts = check_conflicts(store, temp_req, get_embedding_fn=get_embedding)

    if getattr(args, 'json', False):
        output = []
        for c in conflicts:
            existing = c["existing"]
            entry = {
                "existing_id": existing.id,
                "existing_domain": existing.domain,
                "existing_value": existing.value,
                "reason": c["reason"]
            }
            if "similarity" in c:
                entry["similarity"] = c["similarity"]
            if "overlap" in c:
                entry["overlap"] = list(c["overlap"])
            output.append(entry)
        print(json.dumps({
            "conflicts_found": len(output) > 0,
            "count": len(output),
            "conflicts": output
        }, indent=2))
    else:
        print(f"🧵 Loom Conflict Check")
        print()

        if not conflicts:
            print("✓ No conflicts detected")
            return 0

        print(f"⚠️  Found {len(conflicts)} potential conflict(s):")
        print()

        for c in conflicts:
            existing = c["existing"]
            print(f"  {existing.id} [{existing.domain}]")
            print(f"    Existing: {existing.value}")
            print(f"    New:      {value}")
            print(f"    Reason:   {c['reason']}")
            print()

        print("Consider:")
        print("  1. Supersede the existing requirement if this replaces it")
        print("  2. Clarify the scope if both should coexist")
        print("  3. Reject the new requirement if it's invalid")

    return 2 if conflicts else 0


def cmd_supersede(args):
    """Supersede an existing requirement."""
    store = LoomStore(args.project)
    
    print(f"🧵 Loom Supersede — {args.req_id}")
    print()
    
    req = store.get_requirement(args.req_id)
    if not req:
        print(f"Requirement {args.req_id} not found")
        return 1
    
    if req.superseded_at:
        print(f"Already superseded at {req.superseded_at}")
        return 1
    
    store.supersede_requirement(args.req_id)
    print(f"✓ Superseded: {req.value}")
    
    # Show impact
    from docs import analyze_test_impact
    from testspec import TestSpecStore
    spec_store = TestSpecStore(store.data_dir)
    specs = {s.req_id: s for s in spec_store.list_specs()}
    affected = analyze_test_impact(store, req, specs)
    
    if affected:
        print()
        print(f"⚠️  Tests affected ({len(affected)}):")
        for test_id in affected:
            print(f"  - {test_id}")
        print()
        print("Run `loom sync` to update TEST_SPEC.md")
    
    return 0


def cmd_test_add(args):
    """Add or update a test specification."""
    from testspec import TestSpec, TestSpecStore
    
    store = LoomStore(args.project)
    spec_store = TestSpecStore(store.data_dir)
    
    print(f"🧵 Loom Test Add — {args.req_id}")
    print()
    
    # Verify requirement exists
    req = store.get_requirement(args.req_id)
    if not req:
        print(f"Requirement {args.req_id} not found")
        return 1
    
    print(f"Requirement: {req.value}")
    print()
    
    # Get existing spec or create new
    existing = spec_store.get_spec(args.req_id)
    
    spec = TestSpec(
        req_id=args.req_id,
        description=args.description or (existing.description if existing else ""),
        steps=args.steps.split(";") if args.steps else (existing.steps if existing else []),
        expected=args.expected or (existing.expected if existing else ""),
        automated=args.automated or (existing.automated if existing else False),
        test_file=args.test_file or (existing.test_file if existing else None),
        private=args.private or (existing.private if existing else False),
    )
    
    spec_store.add_spec(spec)
    print(f"✓ Test spec saved for {args.req_id}")
    
    if spec.steps:
        print(f"  Steps: {len(spec.steps)}")
    if spec.expected:
        print(f"  Expected: {spec.expected[:50]}...")
    if spec.automated:
        print(f"  Automated: Yes ({spec.test_file})")
    
    return 0


def cmd_test_verify(args):
    """Mark a test as verified."""
    from testspec import TestSpecStore
    
    store = LoomStore(args.project)
    spec_store = TestSpecStore(store.data_dir)
    
    print(f"🧵 Loom Test Verify — {args.req_id}")
    print()
    
    if spec_store.mark_verified(args.req_id):
        print(f"✓ Marked {args.req_id} as verified")
    else:
        print(f"No test spec found for {args.req_id}")
        return 1
    
    return 0


def cmd_test_list(args):
    """List all test specifications."""
    from testspec import TestSpecStore
    
    store = LoomStore(args.project)
    spec_store = TestSpecStore(store.data_dir)
    
    specs = spec_store.list_specs(include_private=not args.public)
    
    # JSON output mode
    if args.json:
        output = [s.to_dict() for s in specs]
        print(json.dumps(output, indent=2))
        return 0
    
    print(f"🧵 Loom Test Specs — Project: {args.project}")
    print()
    
    if not specs:
        print("No test specs defined yet.")
        print("Use `loom test add REQ-xxx --description '...'` to add one.")
        return 0
    
    for spec in specs:
        status = "✅" if spec.last_verified else "⚠️"
        auto = "🤖" if spec.automated else "👤"
        private = "🔒" if spec.private else ""
        
        print(f"{status} {auto} {spec.req_id} {private}")
        print(f"   {spec.description}")
        if spec.last_verified:
            print(f"   Last verified: {spec.last_verified[:10]}")
        print()
    
    return 0


def cmd_test_generate(args):
    """Auto-generate test specifications from acceptance criteria."""
    from testspec import TestSpec, TestSpecStore
    
    store = LoomStore(args.project)
    spec_store = TestSpecStore(store.data_dir)
    
    print(f"🧵 Loom Test Generate — Project: {args.project}")
    print()
    
    reqs = store.list_requirements()
    generated = 0
    skipped = 0
    no_criteria = 0
    
    for req in reqs:
        ac = getattr(req, 'acceptance_criteria', None)
        
        # Skip if no acceptance criteria
        if not ac or len(ac) == 0:
            no_criteria += 1
            continue
        
        # Skip if already has test spec (unless --force)
        existing = spec_store.get_spec(req.id)
        if existing and not args.force:
            skipped += 1
            continue
        
        # Convert acceptance criteria to test steps
        steps = []
        for i, criterion in enumerate(ac, 1):
            steps.append(f"Verify: {criterion}")
        
        # Create test spec
        spec = TestSpec(
            req_id=req.id,
            description=f"Test for: {req.value[:100]}..." if len(req.value) > 100 else f"Test for: {req.value}",
            steps=steps,
            expected="All acceptance criteria pass",
            automated=False,
            test_file=None,
            private=False,
        )
        
        spec_store.add_spec(spec)
        
        # Also link the test spec to the requirement
        store.link_test_spec(req.id, f"TEST-{req.id}")
        
        generated += 1
        if not args.quiet:
            print(f"✓ {req.id} — {len(steps)} steps")
    
    print()
    print(f"Generated: {generated}")
    print(f"Skipped (existing): {skipped}")
    print(f"No acceptance criteria: {no_criteria}")
    
    return 0


def cmd_init_private(args):
    """Initialize PRIVATE.md template."""
    from testspec import create_private_template
    
    store = LoomStore(args.project)
    path = create_private_template(store.data_dir)
    
    print(f"🧵 Loom Private — Created {path}")
    print()
    print("Edit this file to list requirement IDs that should remain private.")
    print("Private requirements will be excluded from public documentation.")
    
    return 0


def cmd_doctor(args):
    """Run health checks on the Loom installation and project."""
    from testspec import TestSpecStore
    import urllib.request
    import urllib.error

    use_json = getattr(args, 'json', False)

    if not use_json:
        print(f"🧵 Loom Doctor — Project: {args.project}")
        print()

    checks = {}
    issues = []
    warnings = []

    # 1. Check Ollama availability
    if not use_json:
        print("Checking Ollama...")
    ollama_ok = False
    try:
        req = urllib.request.Request(
            "http://localhost:11434/api/tags",
            headers={"Content-Type": "application/json"}
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            result = json.loads(resp.read().decode())
            models = [m["name"] for m in result.get("models", [])]
            if "nomic-embed-text" in models or "nomic-embed-text:latest" in models:
                ollama_ok = True
                if not use_json:
                    print("  ✅ Ollama running with nomic-embed-text")
            else:
                warnings.append("nomic-embed-text model not found")
                if not use_json:
                    print(f"  ⚠️  nomic-embed-text not found. Available: {', '.join(models[:5])}")
    except Exception as e:
        issues.append(f"Ollama not reachable: {e}")
        if not use_json:
            print(f"  ❌ Ollama not reachable: {e}")
    checks["ollama"] = {"ok": ollama_ok}

    # 2. Check ChromaDB store
    if not use_json:
        print("Checking store...")
    try:
        store = LoomStore(args.project)
        stats = store.stats()
        checks["store"] = {"ok": True, **stats}
        if not use_json:
            print(f"  ✅ Store accessible ({stats['requirements']} reqs, {stats['implementations']} impls)")
    except Exception as e:
        issues.append(f"Store error: {e}")
        checks["store"] = {"ok": False, "error": str(e)}
        if not use_json:
            print(f"  ❌ Store error: {e}")
        if use_json:
            print(json.dumps({"project": args.project, "healthy": False, "checks": checks, "issues": issues, "warnings": warnings}, indent=2))
        return 1

    # 3. Check for orphan implementations
    if not use_json:
        print("Checking for orphans...")
    all_impls = store.implementations.get(include=["metadatas"])
    orphan_count = 0
    for meta in all_impls.get("metadatas", []):
        satisfies = json.loads(meta.get("satisfies", "[]"))
        for sat in satisfies:
            r = store.get_requirement(sat["req_id"])
            if r is None:
                orphan_count += 1
                warnings.append(f"Impl {meta['id'][:8]}... links to missing {sat['req_id']}")

    checks["orphans"] = {"count": orphan_count}
    if not use_json:
        if orphan_count == 0:
            print("  ✅ No orphan implementations")
        else:
            print(f"  ⚠️  {orphan_count} orphan link(s) found")

    # 4. Check for drift
    if not use_json:
        print("Checking for drift...")
    superseded_reqs = [r for r in store.list_requirements(include_superseded=True) if r.superseded_at]
    drift_count = 0
    for sr in superseded_reqs:
        drift_count += len(store.get_implementations_for_requirement(sr.id))

    checks["drift"] = {"count": drift_count}
    if drift_count > 0:
        warnings.append(f"{drift_count} implementation(s) linked to superseded requirements")
    if not use_json:
        if drift_count == 0:
            print("  ✅ No drift detected")
        else:
            print(f"  ⚠️  {drift_count} implementation(s) need review (linked to superseded reqs)")

    # 5. Check test spec coverage
    if not use_json:
        print("Checking test coverage...")
    try:
        spec_store = TestSpecStore(store.data_dir)
        specs = {s.req_id: s for s in spec_store.list_specs()}
        active_reqs = store.list_requirements(include_superseded=False)

        missing_specs = [r for r in active_reqs if r.id not in specs]
        coverage_pct = ((len(active_reqs) - len(missing_specs)) / len(active_reqs) * 100) if active_reqs else 100

        checks["test_coverage"] = {
            "total": len(active_reqs),
            "covered": len(active_reqs) - len(missing_specs),
            "missing": len(missing_specs),
            "coverage_pct": round(coverage_pct, 1)
        }

        if not use_json:
            if len(missing_specs) == 0:
                print(f"  ✅ 100% test spec coverage")
            else:
                print(f"  ⚠️  {len(missing_specs)} requirement(s) missing test specs ({coverage_pct:.0f}% coverage)")
                if len(missing_specs) <= 5:
                    for r in missing_specs:
                        print(f"      - {r.id}: {r.value[:50]}...")
    except Exception as e:
        if not use_json:
            print(f"  ⚠️  Could not check test specs: {e}")

    # 6. Check for domain consistency
    if not use_json:
        print("Checking domains...")
    valid_domains = {"terminology", "behavior", "ui", "data", "architecture"}
    custom_domains = set()
    for r in store.list_requirements(include_superseded=True):
        if r.domain not in valid_domains:
            custom_domains.add(r.domain)

    if custom_domains:
        warnings.append(f"Non-standard domains: {', '.join(custom_domains)}")
    checks["domains"] = {"custom": list(custom_domains)}

    if not use_json:
        if custom_domains:
            print(f"  ⚠️  Non-standard domains: {', '.join(custom_domains)}")
        else:
            print("  ✅ All domains are standard")

    # Output
    if use_json:
        print(json.dumps({
            "project": args.project,
            "healthy": len(issues) == 0,
            "checks": checks,
            "issues": issues,
            "warnings": warnings
        }, indent=2))
    else:
        print()
        print("─" * 40)
        if issues:
            print(f"❌ {len(issues)} issue(s) found:")
            for issue in issues:
                print(f"   - {issue}")
            return 1
        elif warnings:
            print(f"⚠️  {len(warnings)} warning(s):")
            for warning in warnings[:5]:
                print(f"   - {warning}")
            if len(warnings) > 5:
                print(f"   ... and {len(warnings) - 5} more")
            return 0
        else:
            print("✅ All checks passed!")

    return 1 if issues else 0


def cmd_trace(args):
    """Show bidirectional traceability for a requirement or file."""
    store = LoomStore(args.project)
    target = args.target
    use_json = getattr(args, 'json', False)

    # Determine if target is a requirement ID or a file path
    is_requirement = target.lower().startswith("req-")

    if is_requirement:
        req_id = target
        req = store.get_requirement(req_id)

        if req is None:
            if use_json:
                print(json.dumps({"error": f"Requirement {req_id} not found"}))
            else:
                print(f"❌ Requirement {req_id} not found")
            return 1

        impls = store.get_implementations_for_requirement(req_id)

        from testspec import TestSpecStore
        spec_store = TestSpecStore(store.data_dir)
        spec = spec_store.get_spec(req_id)

        if use_json:
            output = {
                "type": "requirement",
                "id": req_id,
                "domain": req.domain,
                "value": req.value,
                "status": req.status,
                "superseded_at": req.superseded_at,
                "implementations": [
                    {"file": impl.file, "lines": impl.lines}
                    for impl in impls
                ],
                "test_spec": {
                    "description": spec.description,
                    "verified": spec.last_verified is not None
                } if spec else None
            }
            print(json.dumps(output, indent=2))
        else:
            print(f"🧵 Loom Trace — {req_id}")
            print()
            print(f"📋 Requirement [{req.domain}]")
            print(f"   {req.value}")
            print()

            if req.superseded_at:
                print(f"⚠���  SUPERSEDED on {req.superseded_at[:10]}")
                if hasattr(req, 'superseded_by') and req.superseded_by:
                    print(f"   Replaced by: {req.superseded_by}")
                print()

            if not impls:
                print("📁 Implemented by: (none)")
                print("   Run: loom link <file> --req " + req_id)
            else:
                print(f"📁 Implemented by ({len(impls)} file(s)):")
                for impl in impls:
                    lines_info = f" (lines {impl.lines})" if impl.lines else ""
                    print(f"   📄 {impl.file}{lines_info}")

            print()
            if spec:
                status = "✅ verified" if spec.verified_at else "⏳ pending"
                print(f"🧪 Test Spec: {status}")
                print(f"   {spec.test_description[:80]}...")
            else:
                print("🧪 Test Spec: (none)")
                print("   Run: loom test " + req_id + ' --desc "..."')

    else:
        filepath = Path(target).resolve()

        if not filepath.exists():
            if use_json:
                print(json.dumps({"error": f"File not found: {target}"}))
            else:
                print(f"❌ File not found: {target}")
            return 1

        result = store.implementations.get(include=["metadatas"])
        file_impls = []

        for meta in result.get("metadatas", []):
            impl_path = meta.get("file", "")
            if impl_path and Path(impl_path).resolve() == filepath:
                meta["satisfies"] = json.loads(meta.get("satisfies", "[]"))
                file_impls.append(meta)

        all_reqs = set()
        for meta in file_impls:
            for sat in meta.get("satisfies", []):
                all_reqs.add(sat.get("req_id"))

        if use_json:
            req_list = []
            for rid in sorted(all_reqs):
                r = store.get_requirement(rid)
                if r:
                    req_list.append({
                        "id": rid,
                        "domain": r.domain,
                        "value": r.value,
                        "status": r.status,
                        "superseded": r.superseded_at is not None
                    })
                else:
                    req_list.append({"id": rid, "orphan": True})
            print(json.dumps({
                "type": "file",
                "file": target,
                "requirements": req_list
            }, indent=2))
        else:
            print(f"🧵 Loom Trace — {target}")
            print()

            if not file_impls:
                print("📋 Implements: (none)")
                print("   Run: loom link " + str(target) + " --req REQ-xxx")
                return 0

            print(f"📋 Implements ({len(all_reqs)} requirement(s)):")
            print()

            for req_id in sorted(all_reqs):
                req = store.get_requirement(req_id)
                if req:
                    status = "⚠️ superseded" if req.superseded_at else "✓"
                    domain = f"[{req.domain}]"
                    print(f"   {status} {req_id} {domain}")
                    print(f"      {req.value[:70]}...")
                else:
                    print(f"   ❌ {req_id} (not found - orphan link)")
                print()

    return 0


def cmd_refine(args):
    """Elaborate on a requirement with acceptance criteria and conversation context."""
    store = LoomStore(args.project)
    req_id = args.req_id
    
    req = store.get_requirement(req_id)
    if not req:
        print(f"❌ Requirement {req_id} not found")
        return 1
    
    print(f"🔍 Refining {req_id}")
    print(f"   Original: {req.value}")
    print()
    
    # If elaboration provided via args, use it directly
    if args.elaboration:
        elaboration = args.elaboration
    elif args.text:
        # Read from stdin/text for elaboration
        elaboration = args.text
    else:
        # Interactive mode - prompt for elaboration
        print("Enter elaboration (how to satisfy this requirement):")
        print("(Press Ctrl+D when done)")
        try:
            elaboration = sys.stdin.read().strip()
        except KeyboardInterrupt:
            print("\nCancelled")
            return 1
    
    if not elaboration:
        print("❌ No elaboration provided")
        return 1
    
    # Parse acceptance criteria if provided
    acceptance_criteria = []
    if args.criteria:
        acceptance_criteria = args.criteria
    elif args.criteria_text:
        # Parse criteria from text (one per line, or semicolon-separated)
        criteria_text = args.criteria_text
        if ';' in criteria_text:
            acceptance_criteria = [c.strip() for c in criteria_text.split(';') if c.strip()]
        else:
            acceptance_criteria = [c.strip() for c in criteria_text.split('\n') if c.strip()]
    
    # Set status if provided
    status = args.status if args.status else None
    
    # Update the requirement
    updates = {"elaboration": elaboration}
    if acceptance_criteria:
        updates["acceptance_criteria"] = acceptance_criteria
    if args.context:
        updates["conversation_context"] = args.context
    if status:
        updates["status"] = status
    
    updated_req = store.update_requirement(req_id, updates)
    
    if updated_req:
        print(f"✅ Refined {req_id}")
        print()
        print(f"📝 Elaboration:")
        print(f"   {updated_req.elaboration}")
        print()
        if updated_req.acceptance_criteria:
            print(f"✓ Acceptance Criteria ({len(updated_req.acceptance_criteria)}):")
            for i, criterion in enumerate(updated_req.acceptance_criteria, 1):
                print(f"   {i}. {criterion}")
        if updated_req.status != "pending":
            print(f"📊 Status: {updated_req.status}")
        print()
        if updated_req.is_complete():
            print("🎯 Requirement is fully refined!")
        else:
            print("⚠️  Missing: " + (
                "acceptance criteria" if not updated_req.acceptance_criteria else ""
            ))
    else:
        print(f"❌ Failed to update {req_id}")
        return 1
    
    return 0


def cmd_set_status(args):
    """Set the implementation status of a requirement."""
    store = LoomStore(args.project)
    req_id = args.req_id
    status = args.status
    
    valid = ["pending", "in_progress", "implemented", "verified", "superseded"]
    if status not in valid:
        print(f"❌ Invalid status: {status}")
        print(f"   Valid: {', '.join(valid)}")
        return 1
    
    if store.set_requirement_status(req_id, status):
        print(f"✅ {req_id} → {status}")
    else:
        print(f"❌ Requirement {req_id} not found")
        return 1
    
    return 0


def cmd_incomplete(args):
    """List requirements that need refinement."""
    store = LoomStore(args.project)
    
    incomplete = store.get_incomplete_requirements()
    
    if not incomplete:
        print("✅ All requirements are fully refined!")
        return 0
    
    print(f"⚠️  {len(incomplete)} requirement(s) need refinement:")
    print()
    
    for req in incomplete:
        missing = []
        if not req.elaboration:
            missing.append("elaboration")
        if not req.acceptance_criteria:
            missing.append("acceptance criteria")
        
        print(f"  {req.id} [{req.domain}] — missing: {', '.join(missing)}")
        print(f"    {req.value[:70]}...")
        print()
    
    print(f"Run: loom refine <req-id> --elaboration '...' --criteria '...'")
    return 0


# ==================== Specifications ====================

def generate_spec_id() -> str:
    """Generate a unique specification ID."""
    import uuid
    return f"SPEC-{uuid.uuid4().hex[:8]}"


def cmd_spec_add(args):
    """Add a specification to a requirement."""
    store = LoomStore(args.project)
    
    # Verify requirement exists
    req = store.get_requirement(args.req_id)
    if not req:
        print(f"❌ Requirement {args.req_id} not found")
        return 1
    
    # Get description
    if args.description:
        description = args.description
    else:
        print(f"Adding specification to {args.req_id}: {req.value[:60]}...")
        print("Enter specification description:")
        try:
            description = sys.stdin.read().strip()
        except KeyboardInterrupt:
            print("\nCancelled")
            return 1
    
    if not description:
        print("❌ No description provided")
        return 1
    
    # Parse acceptance criteria
    criteria = []
    if args.criteria:
        criteria = args.criteria
    
    # Create specification
    spec_id = generate_spec_id()
    spec = Specification(
        id=spec_id,
        parent_req=args.req_id,
        description=description,
        timestamp=datetime.now(timezone.utc).isoformat(),
        status=args.status or "draft",
        acceptance_criteria=criteria if criteria else None,
        source_doc=args.source_doc
    )
    
    # Get embedding
    embedding = get_embedding(description)
    store.add_specification(spec, embedding)
    
    print(f"✅ Created {spec_id}")
    print(f"   Parent: {args.req_id}")
    print(f"   Description: {description[:80]}...")
    if criteria:
        print(f"   Criteria: {len(criteria)} item(s)")
    
    return 0


def cmd_spec_list(args):
    """List specifications."""
    store = LoomStore(args.project)
    
    if args.req_id:
        specs = store.get_specifications_for_requirement(args.req_id)
    else:
        specs = store.list_specifications(include_superseded=args.all)
    
    # JSON output mode - must be before any other output
    if args.json:
        output = [s.to_dict() for s in specs]
        print(json.dumps(output, indent=2))
        return 0
    
    # Human-readable output
    if args.req_id:
        print(f"📋 Specifications for {args.req_id}")
    else:
        print(f"📋 All Specifications — Project: {args.project}")
    print()
    
    if not specs:
        print("No specifications found.")
        return 0
    
    for spec in specs:
        status = f" ({spec.status})" if spec.status != "draft" else ""
        superseded = " [SUPERSEDED]" if spec.superseded_at else ""
        print(f"{spec.id} → {spec.parent_req}{status}{superseded}")
        print(f"  {spec.description[:80]}...")
        
        # Show linked implementations
        impls = store.get_implementations_for_specification(spec.id)
        if impls:
            print(f"  📁 {len(impls)} implementation(s)")
    
    print()
    print(f"Total: {len(specs)}")
    return 0


def cmd_spec_link(args):
    """Link code to a specification."""
    store = LoomStore(args.project)
    
    # Verify spec exists
    spec = store.get_specification(args.spec_id)
    if not spec:
        print(f"❌ Specification {args.spec_id} not found")
        return 1
    
    # Read file
    filepath = Path(args.file).resolve()
    if not filepath.exists():
        print(f"❌ File not found: {args.file}")
        return 1
    
    content = filepath.read_text()
    
    # Handle line range
    lines_str = args.lines or f"1-{len(content.splitlines())}"
    
    if args.lines:
        start, end = map(int, args.lines.split('-'))
        lines = content.splitlines()[start-1:end]
        content = '\n'.join(lines)
    
    # Generate implementation ID
    impl_id = generate_impl_id(str(filepath), lines_str)
    
    # Check if implementation exists
    existing = store.get_implementation(impl_id)
    if existing:
        # Just add the spec link
        if store.link_implementation_to_spec(impl_id, args.spec_id):
            print(f"✅ Linked existing implementation to {args.spec_id}")
        else:
            print(f"⚠️  Already linked")
        return 0
    
    # Create new implementation linked to spec
    impl = Implementation(
        id=impl_id,
        file=str(filepath),
        lines=lines_str,
        content=content,
        content_hash=generate_content_hash(content),
        timestamp=datetime.now(timezone.utc).isoformat(),
        satisfies=[{"req_id": spec.parent_req, "req_version": "current"}],
        satisfies_specs=[args.spec_id]
    )
    
    embedding = get_embedding(content)
    store.add_implementation(impl, embedding)
    
    print(f"✅ Linked {filepath.name}:{lines_str} to {args.spec_id}")
    print(f"   (Also linked to parent requirement {spec.parent_req})")
    return 0


# ==================== Patterns ====================

def generate_pattern_id() -> str:
    """Generate a unique pattern ID."""
    import uuid
    return f"PAT-{uuid.uuid4().hex[:8]}"


def cmd_pattern_add(args):
    """Add a shared design pattern."""
    store = LoomStore(args.project)
    
    if not args.name:
        print("❌ Pattern name required (--name)")
        return 1
    
    if not args.description:
        print("Enter pattern description:")
        try:
            description = sys.stdin.read().strip()
        except KeyboardInterrupt:
            print("\nCancelled")
            return 1
    else:
        description = args.description
    
    if not description:
        print("❌ No description provided")
        return 1
    
    # Parse requirements
    applies_to = args.reqs or []
    
    # Verify requirements exist
    for req_id in applies_to:
        if not store.get_requirement(req_id):
            print(f"⚠️  Requirement {req_id} not found (continuing anyway)")
    
    pattern_id = generate_pattern_id()
    pattern = Pattern(
        id=pattern_id,
        name=args.name,
        description=description,
        timestamp=datetime.now(timezone.utc).isoformat(),
        applies_to=applies_to
    )
    
    embedding = get_embedding(f"{args.name}: {description}")
    store.add_pattern(pattern, embedding)
    
    print(f"✅ Created {pattern_id}: {args.name}")
    print(f"   {description[:80]}...")
    if applies_to:
        print(f"   Applies to: {', '.join(applies_to)}")
    
    return 0


def cmd_pattern_list(args):
    """List patterns."""
    store = LoomStore(args.project)
    
    patterns = store.list_patterns(include_deprecated=args.all)
    
    # JSON output mode - must be before any other output
    if args.json:
        output = [p.to_dict() for p in patterns]
        print(json.dumps(output, indent=2))
        return 0
    
    # Human-readable output
    print(f"🔷 Design Patterns — Project: {args.project}")
    print()
    
    if not patterns:
        print("No patterns found.")
        return 0
    
    for pattern in patterns:
        status = f" [DEPRECATED]" if pattern.status == "deprecated" else ""
        print(f"{pattern.id}: {pattern.name}{status}")
        print(f"  {pattern.description[:80]}...")
        print(f"  Applies to: {len(pattern.applies_to)} requirement(s)")
        
        # Show linked implementations
        impls = store.get_implementations_for_pattern(pattern.id)
        if impls:
            print(f"  📁 {len(impls)} implementation(s)")
        print()
    
    print(f"Total: {len(patterns)}")
    return 0


def cmd_pattern_apply(args):
    """Apply a pattern to additional requirements."""
    store = LoomStore(args.project)
    
    pattern = store.get_pattern(args.pattern_id)
    if not pattern:
        print(f"❌ Pattern {args.pattern_id} not found")
        return 1
    
    added = 0
    for req_id in args.reqs:
        if store.add_requirement_to_pattern(args.pattern_id, req_id):
            print(f"✅ Applied {args.pattern_id} to {req_id}")
            added += 1
        else:
            print(f"⚠️  {req_id} already has this pattern or not found")
    
    print(f"\nAdded {added} requirement(s) to pattern")
    return 0


# ==================== Coverage ====================

def cmd_coverage(args):
    """Three-layer coverage analysis: Requirements → Specs → Implementations/Tests."""
    from testspec import TestSpecStore

    store = LoomStore(args.project)
    use_json = getattr(args, 'json', False)

    reqs = store.list_requirements(include_superseded=False)
    spec_store = TestSpecStore(store.data_dir)
    all_specs = store.list_specifications()

    # ----- Layer 1: Requirements → Specifications -----
    reqs_without_specs = []
    reqs_with_specs = []
    for req in reqs:
        specs = store.get_specifications_for_requirement(req.id)
        entry = {
            "id": req.id,
            "domain": req.domain,
            "value": req.value,
            "status": req.status,
            "spec_ids": [s.id for s in specs],
            "direct_implementations": [
                {"file": i.file, "lines": i.lines}
                for i in store.get_implementations_for_requirement(req.id)
                if not (i.satisfies_specs or [])
            ],
        }
        if specs:
            reqs_with_specs.append(entry)
        else:
            reqs_without_specs.append(entry)

    # ----- Layer 2: Specifications → Implementations -----
    specs_without_impls = []
    specs_with_impls = []
    # ----- Layer 3: Specifications → Tests -----
    specs_without_tests = []
    specs_with_tests = []

    for spec in all_specs:
        if spec.superseded_at:
            continue
        impls = store.get_implementations_for_specification(spec.id)
        tests = spec_store.get_specs_for_spec_id(spec.id)

        spec_entry = {
            "id": spec.id,
            "parent_req": spec.parent_req,
            "description": spec.description[:80],
            "status": spec.status,
            "implementation_files": [i.file for i in impls],
            "test_ids": [t.req_id for t in tests],  # TestSpecs are indexed by req_id
        }
        if impls:
            specs_with_impls.append(spec_entry)
        else:
            specs_without_impls.append(spec_entry)
        if tests:
            specs_with_tests.append(spec_entry)
        else:
            specs_without_tests.append(spec_entry)

    # ----- Aggregates -----
    total_reqs = len(reqs)
    active_specs = [s for s in all_specs if not s.superseded_at]
    total_specs = len(active_specs)

    spec_cov_pct = (len(reqs_with_specs) / total_reqs * 100) if total_reqs else 100
    impl_cov_pct = (len(specs_with_impls) / total_specs * 100) if total_specs else 0
    test_cov_pct = (len(specs_with_tests) / total_specs * 100) if total_specs else 0

    # Optional: scan for likely implementations
    scan_suggestions = {}
    if getattr(args, 'scan', False) and specs_without_impls:
        # Scan for specs, not requirements
        scan_suggestions = _scan_project_for_specs(store, active_specs, specs_without_impls, args)

    if use_json:
        output = {
            "project": args.project,
            "layer_1_req_to_spec": {
                "total_requirements": total_reqs,
                "coverage_pct": round(spec_cov_pct, 1),
                "with_specs": len(reqs_with_specs),
                "without_specs": reqs_without_specs,
            },
            "layer_2_spec_to_impl": {
                "total_specs": total_specs,
                "coverage_pct": round(impl_cov_pct, 1),
                "with_impls": len(specs_with_impls),
                "without_impls": specs_without_impls,
            },
            "layer_3_spec_to_test": {
                "total_specs": total_specs,
                "coverage_pct": round(test_cov_pct, 1),
                "with_tests": len(specs_with_tests),
                "without_tests": specs_without_tests,
            },
        }
        if scan_suggestions:
            output["scan_suggestions"] = scan_suggestions
        print(json.dumps(output, indent=2))
        return 0

    # Human-readable
    print(f"🧵 Loom Coverage — Project: {args.project}")
    print()
    print("Three-layer traceability: Requirements → Specs → Implementations/Tests")
    print()
    print(f"Layer 1 — Requirements have specs:    {len(reqs_with_specs)}/{total_reqs} ({spec_cov_pct:.0f}%)")
    print(f"Layer 2 — Specs have implementations: {len(specs_with_impls)}/{total_specs} ({impl_cov_pct:.0f}%)")
    print(f"Layer 3 — Specs have tests:           {len(specs_with_tests)}/{total_specs} ({test_cov_pct:.0f}%)")

    if reqs_without_specs:
        print()
        print(f"--- Requirements Without Specs ({len(reqs_without_specs)}) ---")
        print("(These requirements need a specification describing HOW to implement them.)")
        for e in reqs_without_specs:
            direct = f"  [{len(e['direct_implementations'])} direct impl link(s)]" if e['direct_implementations'] else ""
            print(f"  {e['id']} [{e['domain']}] {e['value'][:60]}{direct}")
            print(f"    → Run: loom spec {e['id']} -d \"specification text\"")

    if specs_without_impls:
        print()
        print(f"--- Specs Without Implementations ({len(specs_without_impls)}) ---")
        for e in specs_without_impls:
            print(f"  {e['id']} (parent: {e['parent_req']}) {e['description'][:60]}")
            if e['id'] in scan_suggestions:
                for s in scan_suggestions[e['id']]:
                    print(f"    ? possible match: {s['file']} (similarity {s['similarity']:.0%})")
            else:
                print(f"    → Run: loom spec-link {e['id']} <file>")

    if specs_without_tests:
        print()
        print(f"--- Specs Without Tests ({len(specs_without_tests)}) ---")
        for e in specs_without_tests:
            files = ", ".join(e['implementation_files'][:3]) if e['implementation_files'] else "no code linked"
            print(f"  {e['id']} (parent: {e['parent_req']}) {e['description'][:60]}")
            print(f"    code: {files}")

    if not reqs_without_specs and not specs_without_impls and not specs_without_tests:
        print()
        print("All requirements have specs, and all specs have implementations and tests.")

    return 0


def _scan_project_for_specs(store, all_specs, specs_without_impls, args):
    """Scan project source files to find likely implementations for unlinked specifications."""
    import glob as glob_mod

    scan_dir = getattr(args, 'scan_dir', None) or '.'
    suggestions = {}

    # Find source files (skip tests, docs, venvs)
    patterns = ['**/*.py', '**/*.js', '**/*.ts', '**/*.dart', '**/*.go', '**/*.rs', '**/*.java']
    skip_dirs = {'.venv', 'venv', 'node_modules', '__pycache__', '.git', 'docs', '.pytest_cache'}

    source_files = []
    for pattern in patterns:
        for path in glob_mod.glob(os.path.join(scan_dir, pattern), recursive=True):
            if not any(skip in path.split(os.sep) for skip in skip_dirs):
                source_files.append(path)

    if not source_files:
        return suggestions

    # Only scan specs that have no impls
    unlinked_spec_ids = {s['id'] for s in specs_without_impls}
    specs_to_scan = [s for s in all_specs if s.id in unlinked_spec_ids]

    for spec in specs_to_scan:
        spec_embedding = get_embedding(spec.description)
        matches = []

        for fpath in source_files:
            try:
                content = Path(fpath).read_text(errors='ignore')[:1000]
                if len(content.strip()) < 20:
                    continue
                file_embedding = get_embedding(content)

                dist = sum((a - b) ** 2 for a, b in zip(spec_embedding, file_embedding)) ** 0.5
                similarity = max(0, 1 - (dist / 2))

                if similarity > 0.6:
                    matches.append({"file": fpath, "similarity": round(similarity, 3)})
            except Exception:
                continue

        if matches:
            matches.sort(key=lambda m: m['similarity'], reverse=True)
            suggestions[spec.id] = matches[:3]

    return suggestions


# ==================== Traceability Chain ====================

def cmd_chain(args):
    """Show full traceability chain for a requirement."""
    store = LoomStore(args.project)
    use_json = getattr(args, 'json', False)

    req_id = args.req_id
    req = store.get_requirement(req_id)

    if not req:
        if use_json:
            print(json.dumps({"error": f"Requirement {req_id} not found"}))
        else:
            print(f"❌ Requirement {req_id} not found")
        return 1

    patterns = store.get_patterns_for_requirement(req_id)
    specs = store.get_specifications_for_requirement(req_id)
    impls = store.get_implementations_for_requirement(req_id)
    direct_impls = [i for i in impls if not i.satisfies_specs]

    from testspec import TestSpecStore
    spec_store = TestSpecStore(store.data_dir)
    test = spec_store.get_spec(req_id)

    if use_json:
        spec_data = []
        for spec in specs:
            spec_impls = store.get_implementations_for_specification(spec.id)
            spec_data.append({
                "id": spec.id,
                "description": spec.description,
                "status": spec.status,
                "implementations": [
                    {"file": si.file, "lines": si.lines} for si in spec_impls
                ]
            })

        output = {
            "id": req_id,
            "domain": req.domain,
            "value": req.value,
            "status": req.status,
            "elaboration": req.elaboration,
            "rationale": req.rationale,
            "patterns": [{"id": p.id, "name": p.name} for p in patterns],
            "specifications": spec_data,
            "direct_implementations": [
                {"file": i.file, "lines": i.lines} for i in direct_impls
            ],
            "test_spec": {
                "description": test.description,
                "verified": test.last_verified is not None
            } if test else None
        }
        print(json.dumps(output, indent=2))
    else:
        print(f"🔗 Traceability Chain — {req_id}")
        print()

        print(f"📋 REQUIREMENT [{req.domain}]")
        print(f"   {req.value}")
        if req.elaboration:
            print(f"   📝 {req.elaboration[:60]}...")
        print()

        if patterns:
            print(f"🔷 PATTERNS ({len(patterns)})")
            for p in patterns:
                print(f"   {p.id}: {p.name}")
            print()

        if specs:
            print(f"📐 SPECIFICATIONS ({len(specs)})")
            for spec in specs:
                status_icon = "✓" if spec.status == "implemented" else "○"
                print(f"   {status_icon} {spec.id}: {spec.description[:50]}...")
                spec_impls = store.get_implementations_for_specification(spec.id)
                for impl in spec_impls:
                    print(f"      📁 {impl.file}:{impl.lines}")
            print()

        if direct_impls:
            print(f"📁 DIRECT IMPLEMENTATIONS ({len(direct_impls)})")
            for impl in direct_impls:
                print(f"   {impl.file}:{impl.lines}")
            print()

        if test:
            status = "✅ verified" if test.last_verified else "⏳ pending"
            print(f"🧪 TEST SPECIFICATION: {status}")
            print(f"   {test.description[:60]}...")
        else:
            print("🧪 TEST SPECIFICATION: (none)")

    return 0


def main():
    parser = argparse.ArgumentParser(description="Loom - Requirements traceability")
    parser.add_argument("--project", "-p", default=None, help="Project name")
    
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # extract
    p_extract = subparsers.add_parser("extract", help="Extract requirements")
    p_extract.add_argument("--session", help="Session key")
    p_extract.add_argument("--msg-id", help="Message ID for provenance")
    p_extract.add_argument("--text", "-t", help="Requirement text")
    p_extract.add_argument("--rationale", "-r", help="Why this requirement exists")
    
    # check
    p_check = subparsers.add_parser("check", help="Check for drift")
    p_check.add_argument("file", help="File to check")
    p_check.add_argument("--lines", help="Line range (e.g., 42-78)")
    p_check.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # link
    p_link = subparsers.add_parser("link", help="Link code to requirements or specifications")
    p_link.add_argument("file", help="File to link")
    p_link.add_argument("--lines", help="Line range")
    p_link.add_argument("--req", action="append", help="Requirement ID(s) — direct link (use sparingly; prefer --spec)")
    p_link.add_argument("--spec", action="append", help="Specification ID(s) — preferred link target")
    
    # status
    p_status = subparsers.add_parser("status", help="Show status")
    p_status.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # query
    p_query = subparsers.add_parser("query", help="Search requirements")
    p_query.add_argument("text", help="Search text")
    p_query.add_argument("--limit", "-n", type=int, default=5)
    p_query.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # list
    p_list = subparsers.add_parser("list", help="List requirements")
    p_list.add_argument("--all", "-a", action="store_true", help="Include superseded")
    p_list.add_argument("--json", "-j", action="store_true", help="Output as JSON (for API)")
    
    # sync
    p_sync = subparsers.add_parser("sync", help="Generate REQUIREMENTS.md and TEST_SPEC.md")
    p_sync.add_argument("--output", "-o", help="Output directory (default: current)")
    p_sync.add_argument("--public", action="store_true", help="Exclude private requirements")
    
    # conflicts
    p_conflicts = subparsers.add_parser("conflicts", help="Check for conflicts")
    p_conflicts.add_argument("--text", "-t", required=True, help="Requirement to check")
    p_conflicts.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # supersede
    p_supersede = subparsers.add_parser("supersede", help="Supersede a requirement")
    p_supersede.add_argument("req_id", help="Requirement ID to supersede")
    
    # test add
    p_test_add = subparsers.add_parser("test", help="Add/update test specification")
    p_test_add.add_argument("req_id", help="Requirement ID")
    p_test_add.add_argument("--description", "-d", help="Test description")
    p_test_add.add_argument("--steps", "-s", help="Test steps (semicolon-separated)")
    p_test_add.add_argument("--expected", "-e", help="Expected outcome")
    p_test_add.add_argument("--automated", "-a", action="store_true", help="Mark as automated")
    p_test_add.add_argument("--test-file", help="Path to test file")
    p_test_add.add_argument("--private", action="store_true", help="Mark test as private")
    
    # test verify
    p_verify = subparsers.add_parser("verify", help="Mark test as verified")
    p_verify.add_argument("req_id", help="Requirement ID")
    
    # test list
    p_tests = subparsers.add_parser("tests", help="List test specifications")
    p_tests.add_argument("--public", action="store_true", help="Exclude private tests")
    p_tests.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # test-generate
    p_test_gen = subparsers.add_parser("test-generate", help="Auto-generate test specs from acceptance criteria")
    p_test_gen.add_argument("--force", "-f", action="store_true", help="Overwrite existing test specs")
    p_test_gen.add_argument("--quiet", "-q", action="store_true", help="Minimal output")
    
    # init-private
    p_private = subparsers.add_parser("init-private", help="Initialize PRIVATE.md template")
    
    # doctor
    p_doctor = subparsers.add_parser("doctor", help="Run health checks")
    p_doctor.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # trace (bidirectional traceability)
    p_trace = subparsers.add_parser("trace", help="Show bidirectional traceability for a requirement or file")
    p_trace.add_argument("target", help="Requirement ID (REQ-xxx) or file path")
    p_trace.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # refine (elaborate requirements)
    p_refine = subparsers.add_parser("refine", help="Elaborate a requirement with acceptance criteria")
    p_refine.add_argument("req_id", help="Requirement ID")
    p_refine.add_argument("--elaboration", "-e", help="How to satisfy this requirement")
    p_refine.add_argument("--text", "-t", help="Elaboration text (alternative to -e)")
    p_refine.add_argument("--criteria", "-c", action="append", help="Acceptance criterion (repeatable)")
    p_refine.add_argument("--criteria-text", help="Acceptance criteria (semicolon or newline separated)")
    p_refine.add_argument("--context", help="Conversation context excerpt")
    p_refine.add_argument("--status", "-s", help="Set status (pending, in_progress, implemented, verified)")
    
    # set-status
    p_set_status = subparsers.add_parser("set-status", help="Set requirement implementation status")
    p_set_status.add_argument("req_id", help="Requirement ID")
    p_set_status.add_argument("status", help="Status: pending, in_progress, implemented, verified, superseded")
    
    # incomplete (list requirements needing refinement)
    p_incomplete = subparsers.add_parser("incomplete", help="List requirements needing refinement")
    
    # spec (add specification to requirement)
    p_spec = subparsers.add_parser("spec", help="Add specification to a requirement")
    p_spec.add_argument("req_id", help="Parent requirement ID")
    p_spec.add_argument("--description", "-d", help="Specification description")
    p_spec.add_argument("--criteria", "-c", action="append", help="Acceptance criterion (repeatable)")
    p_spec.add_argument("--status", "-s", help="Status: draft, approved, implemented, verified")
    p_spec.add_argument("--source-doc", help="Source document path")
    
    # specs (list specifications)
    p_specs = subparsers.add_parser("specs", help="List specifications")
    p_specs.add_argument("--req", dest="req_id", help="Filter by requirement ID")
    p_specs.add_argument("--all", "-a", action="store_true", help="Include superseded")
    p_specs.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # spec-link (link code to specification)
    p_spec_link = subparsers.add_parser("spec-link", help="Link code to a specification")
    p_spec_link.add_argument("spec_id", help="Specification ID")
    p_spec_link.add_argument("file", help="File to link")
    p_spec_link.add_argument("--lines", help="Line range (e.g., 42-78)")
    
    # pattern (add design pattern)
    p_pattern = subparsers.add_parser("pattern", help="Add a shared design pattern")
    p_pattern.add_argument("--name", "-n", required=True, help="Pattern name")
    p_pattern.add_argument("--description", "-d", help="Pattern description")
    p_pattern.add_argument("--reqs", action="append", help="Requirement IDs this applies to")
    
    # patterns (list patterns)
    p_patterns = subparsers.add_parser("patterns", help="List design patterns")
    p_patterns.add_argument("--all", "-a", action="store_true", help="Include deprecated")
    p_patterns.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    # pattern-apply (apply pattern to requirements)
    p_pattern_apply = subparsers.add_parser("pattern-apply", help="Apply pattern to requirements")
    p_pattern_apply.add_argument("pattern_id", help="Pattern ID")
    p_pattern_apply.add_argument("reqs", nargs="+", help="Requirement IDs to apply to")
    
    # coverage (gap analysis)
    p_coverage = subparsers.add_parser("coverage", help="Show requirements missing implementations or tests")
    p_coverage.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    p_coverage.add_argument("--scan", action="store_true", help="Scan project files for likely implementations")
    p_coverage.add_argument("--scan-dir", help="Directory to scan (default: current)")

    # chain (full traceability chain)
    p_chain = subparsers.add_parser("chain", help="Show full traceability chain for a requirement")
    p_chain.add_argument("req_id", help="Requirement ID")
    p_chain.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    args = parser.parse_args()
    
    if not args.project:
        args.project = get_project_name()
    
    commands = {
        "extract": cmd_extract,
        "check": cmd_check,
        "link": cmd_link,
        "status": cmd_status,
        "query": cmd_query,
        "list": cmd_list,
        "sync": cmd_sync,
        "conflicts": cmd_conflicts,
        "supersede": cmd_supersede,
        "test": cmd_test_add,
        "verify": cmd_test_verify,
        "tests": cmd_test_list,
        "test-generate": cmd_test_generate,
        "init-private": cmd_init_private,
        "doctor": cmd_doctor,
        "trace": cmd_trace,
        "refine": cmd_refine,
        "set-status": cmd_set_status,
        "incomplete": cmd_incomplete,
        "spec": cmd_spec_add,
        "specs": cmd_spec_list,
        "spec-link": cmd_spec_link,
        "pattern": cmd_pattern_add,
        "patterns": cmd_pattern_list,
        "pattern-apply": cmd_pattern_apply,
        "coverage": cmd_coverage,
        "chain": cmd_chain,
    }
    
    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
