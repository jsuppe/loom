#!/usr/bin/env python3
"""
Thin compatibility shim around ``loom.exec_cli:main``.

After ``pip install`` the ``loom_exec`` console script registered in
``pyproject.toml`` is the canonical entry point. This script lets a
repo clone run the executor without an install.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from loom.exec_cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
